# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Flask Configuration
FLASK_ENV=development
FLASK_SECRET_KEY=your_very_secret_key_here_change_this
FLASK_DEBUG=True

# Firebase Configuration (if not using serviceAccountKey.json)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your_project.firebaseio.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# External APIs
OPENROUTE_API_KEY=your_openroute_service_api_key
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Application Settings
DEFAULT_MAP_LAT=28.6139
DEFAULT_MAP_LNG=77.2090
DEFAULT_ZOOM_LEVEL=12

# Charging Station Configuration
BATTERY_THRESHOLD_FOR_CHARGING=30
CHARGING_TIME_PER_PERCENT=1.5
